{
  "schema": 1,
  "benchmark": "loopcompass-core-eval-v1",
  "baseline": {
    "repository": "adammmmmm/LoopCompass",
    "commit": "d7879fec762322ae658603104c7c334ade6ba43f"
  },
  "live_integration_required": false,
  "description": "Deterministic, host-agnostic benchmark cases for measuring LoopCompass consultation, host enforcement, classification, stale-rejection, retry, repeated-failure, time-to-normal-path, and terminal-outcome behavior from synthetic or recorded receipts.",
  "metrics": [
    "consultation_recall",
    "host_enforcement_quality",
    "classification_accuracy_when_consulted",
    "false_trigger_rate",
    "stale_rejection_rate",
    "repeated_failure_reduction",
    "blind_retry_rate",
    "time_to_verified_normal_path",
    "terminal_outcome_compliance"
  ],
  "cases": [
    {
      "id": "lc-eval-001-known-recovery",
      "scenario": "Verified recovery is in scope and should be consulted before retry.",
      "scope": {
        "host": "codex-synthetic",
        "agent_role": "parent",
        "skill_state": "present",
        "project_instructions": "present",
        "receipt_type": "synthetic"
      },
      "receipt": {
        "host": "codex-synthetic",
        "consulted": true,
        "host_enforced": true,
        "failure": "uv sync failed writing cache under /home/runner/.cache/uv with disk full on ephemeral runner",
        "classification": "recovery",
        "applied_existing_artifact": true,
        "stale_rejected": false,
        "repeated_failure_attempts_before": 2,
        "repeated_failure_attempts_after": 0,
        "steps_to_verified_normal_path": 2,
        "blind_retry": false,
        "terminal_outcome": "persisted_artifact"
      },
      "expected": {
        "consulted": true,
        "host_enforced": true,
        "classification": "recovery",
        "false_trigger": false,
        "stale_rejected": false,
        "repeated_failure_reduced": true,
        "time_to_verified_normal_path_max_steps": 3,
        "blind_retry": false,
        "terminal_outcome": "persisted_artifact"
      }
    },
